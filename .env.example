# Général Midi Boop Environment Configuration
# Copy this file to .env and adjust values as needed.

# Server
# PORT=8080
# GMBOOP_SERVER_PORT=8080
# GMBOOP_SERVER_WS_PORT=8080

# Database
# GMBOOP_DATABASE_PATH=./data/gmboop.db

# Logging
# GMBOOP_LOG_LEVEL=info
# GMBOOP_LOG_FILE=./logs/gmboop.log

# Bluetooth
# GMBOOP_BLE_ENABLED=false

# Serial
# GMBOOP_SERIAL_ENABLED=false
# GMBOOP_SERIAL_BAUD_RATE=31250

# Authentication (optional - leave empty to disable)
# GMBOOP_API_TOKEN=your-secret-token-here
