# Ma-est-tro Environment Configuration
# Copy this file to .env and adjust values as needed.

# Server
# PORT=8080
# MAESTRO_SERVER_PORT=8080
# MAESTRO_SERVER_WS_PORT=8080

# Database
# MAESTRO_DATABASE_PATH=./data/midimind.db

# Logging
# MAESTRO_LOG_LEVEL=info
# MAESTRO_LOG_FILE=./logs/midimind.log

# Bluetooth
# MAESTRO_BLE_ENABLED=false

# Serial
# MAESTRO_SERIAL_ENABLED=false
# MAESTRO_SERIAL_BAUD_RATE=31250
