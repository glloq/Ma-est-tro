{
  "command": "filter_clear",
  "module": "RoutingCommands.js",
  "criticality": "medium",
  "description": "Clear filter on a route (sets filter to empty object). Validator requires `routeId`.",
  "cases": [
    {
      "name": "nominal — clear filter",
      "type": "success",
      "input": {
        "routeId": "route-1"
      },
      "output_shape": {
        "type": "response",
        "data": {
          "success": "boolean"
        }
      },
      "output_snapshot": {
        "type": "response",
        "data": {
          "success": true
        }
      }
    },
    {
      "name": "error — missing routeId",
      "type": "error",
      "input": {},
      "output_shape": {
        "type": "error",
        "code": "string",
        "error": "string"
      },
      "output_snapshot": {
        "type": "error",
        "code": "ERR_VALIDATION",
        "error": "Invalid filter_clear data: routeId is required"
      }
    }
  ]
}
