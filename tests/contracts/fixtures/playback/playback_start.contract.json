{
  "command": "playback_start",
  "module": "PlaybackCommands.js",
  "criticality": "high",
  "description": "Load a MIDI file, auto-load saved channel routings, pick output device, start playback.",
  "cases": [
    {
      "name": "nominal — start with fileId and explicit outputDevice",
      "type": "success",
      "input": {
        "fileId": "file-001",
        "outputDevice": "out-1"
      },
      "output_shape": {
        "type": "response",
        "data": {
          "success": "boolean",
          "fileInfo": "object",
          "outputDevice": "string",
          "loadedRoutings": "number"
        }
      },
      "output_snapshot": {
        "type": "response",
        "data": {
          "success": true,
          "fileInfo": {
            "filename": "test.mid",
            "duration": 120,
            "tracks": 3,
            "events": 42,
            "tempo": 120,
            "channels": []
          },
          "outputDevice": "out-1",
          "loadedRoutings": 0
        }
      }
    },
    {
      "name": "nominal — start without outputDevice (falls back to first enabled output)",
      "type": "success",
      "input": {
        "fileId": "file-001"
      },
      "output_shape": {
        "type": "response",
        "data": {
          "success": "boolean",
          "fileInfo": "object",
          "outputDevice": "string",
          "loadedRoutings": "number"
        }
      },
      "output_snapshot": {
        "type": "response",
        "data": {
          "success": true,
          "fileInfo": {
            "filename": "test.mid",
            "duration": 120,
            "tracks": 3,
            "events": 42,
            "tempo": 120,
            "channels": []
          },
          "outputDevice": "out-default",
          "loadedRoutings": 0
        }
      }
    },
    {
      "name": "error — missing fileId AND missing outputDevice (validator)",
      "type": "error",
      "input": {},
      "notes": "Blocked at CommandRegistry validator (validatePlaybackCommand) which requires fileId OR outputDevice. Error message is prefixed with 'Invalid playback_start data: '.",
      "output_shape": {
        "type": "error",
        "code": "string",
        "error": "string"
      },
      "output_snapshot": {
        "type": "error",
        "code": "ERR_VALIDATION",
        "error": "Invalid playback_start data: fileId or outputDevice is required"
      }
    },
    {
      "name": "error — missing fileId with outputDevice provided (handler)",
      "type": "error",
      "input": {
        "outputDevice": "out-1"
      },
      "notes": "Passes validator (outputDevice satisfies it), but the handler dereferences fileId first and throws.",
      "output_shape": {
        "type": "error",
        "code": "string",
        "error": "string"
      },
      "output_snapshot": {
        "type": "error",
        "code": "ERR_VALIDATION",
        "error": "fileId is required"
      }
    },
    {
      "name": "error — no output devices available",
      "type": "error",
      "input": {
        "fileId": "file-001"
      },
      "preconditions": {
        "deviceManager.getDeviceList": "returns empty list (no enabled outputs)"
      },
      "output_shape": {
        "type": "error",
        "code": "string",
        "error": "string"
      },
      "output_snapshot": {
        "type": "error",
        "code": "ERR_CONFIGURATION",
        "error": "No output devices available"
      }
    }
  ]
}
